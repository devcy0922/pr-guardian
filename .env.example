# ── GitHub ──
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=

# ── LLM Gateway ──
LLM_GATEWAY_URL=https://gateway.example.com/v1
LLM_MODEL=qwen3-8b
LLM_API_KEY=

# ── Server ──
PORT=3000
LOG_LEVEL=info

# ── Redis (shared-redis — 중복 실행 방지 락)
# 형식: redis://[:password@]host:port[/db]
# 예시: redis://cache:6379
# 미설정 시: 락 비활성화(fail-open)로 동작함
REDIS_URL=redis://cache:6379

# ── Retry 트리거 설정 ──
# GitHub PR에 이 이름의 라벨을 부착하면 리뷰가 재실행됨
RETRY_LABEL_NAME=ai-review

# ── Jira (선택) ──
JIRA_BASE_URL=https://jira.example.com
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE_ID=

# ── PM Automation ──
AUTO_PM_ENABLED=true
AUTO_PM_PROJECT_NUMBER=1
AUTO_PM_CREATE_MILESTONE=false

# ── Security ──
SENSITIVE_HOSTNAMES=internal-node,compute-node

# ── 선택적 배포 동기화 ──
SYNC_SOURCE_DIR=
SYNC_TARGET=
